// Application Setup (formerly helpers.scss.erb)
//
// This is the single source of truth for all shared Sass configurations.
// It should be imported by any stylesheet that needs access to variables,
// functions, or mixins.
//
// It does NOT output any CSS on its own. It only provides setup tools.

// 1. Core tools and foundational variables (no Bootstrap yet).
@import './_tools/constants';
@import './_settings/colors';
@import './_settings/variables';
@import './_settings/spacing';
@import './_settings/typography';
@import './_tools/functions';
@import './_tools/color_calculations';
@import './_tools/mixins/_index';

// 2. Load Bootstrap's functions and variables so our components can use them.
// Note: We only import the parts of Bootstrap that provide variables/mixins,
// not the parts that generate actual CSS.
@import 'bootstrap/scss/functions';
@import './_settings/custom_bootstrap_variables';
@import 'bootstrap/scss/mixins';
