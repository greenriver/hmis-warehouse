= simple_form_for [:admin, @user] do |f|
  = render 'admin/users/form_fields', f: f

  - if @user.new_record?
    .alert.alert-info.mt-4
      %p This user account will be created but no notification will be sent.  Ensure the user is setup with a matching email address in their Identity Provider.
  .form-actions.mt-4
    = f.button :submit, class: 'btn btn-primary'

-# TODO START_ACL cleanup after ACL migration
- if @user.using_acls?
  = render '/users/access_control_table', user: @user

-# When we've connected contacts to user accounts, this would be a good roll-up place to show the contact relationships
-# - unless @user.new_record?
-#   = render 'contact_relationships'
