.table-responsive
  %table.table.table-striped
    %thead
      %tr
        %th Name
        %th Email
        %th Roles
        %th Audit
        %th Status
        %th
    %tbody
      - list.each do |user|
        %tr
          %td= user.name
          %td= user.email
          %td= user.legacy_roles.map(&:name).uniq.join(', ')
          %td
            = link_to admin_user_audit_path(user), class: 'btn btn-sm btn-secondary btn-icon-only' do
              %i.icon-eye{data: { 'bs-toggle' => :tooltip, 'bs-title' => 'Audit'}}
          %td
            = render 'user_status', user: user
          %td
            = simple_form_for(user, url: reactivate_admin_inactive_user_path(user)) do |f|
              = f.button :button, data: { confirm: 'Re-activate this account? Access will be restored and the account re-enabled in your identity provider.' }, class: 'btn btn-primary' do
                Re-activate
