:ruby
  items = []

  items << { link_to: { path: edit_admin_user_path(id: user) }, icon: 'pencil', label: 'Edit Account' }

  if user.training_required? && user.required_training_courses.present?
    items << { link_to: { path: edit_admin_user_training_path(id: user) }, icon: 'pencil', label: 'Edit Training' }
  end

  if can_audit_users?
    items << { link_to: { path: admin_user_audit_path(user) }, icon: 'eye', label: 'Audit' }
  end

  if can_impersonate_users? && user.impersonateable_by?(true_user)
    items << { link_to: { path: impersonate_admin_user_path(true_user, become_id: user.id), method: :post }, icon: 'enter', label: 'Become' }
  end

  items << { disabled: !user.idp_password_management_enabled?, link_to: { path: expire_password_admin_user_path(user), method: :patch, class: ['label-warning'], data: {confirm: "Would you really like to force a password reset for the account? #{user.name} will be required to choose a new password on next login." } }, icon: 'lock', label: 'Force Password Reset' }

  items << { disabled: current_user.id == user.id, link_to: { path: admin_user_path(user), method: :delete, class: ['label-danger'], data: { confirm: "Would you really like to de-activate the account? #{user.name} will no longer be able to login." } }, icon: 'cross', label: 'De-Activate' }

= action_menu_or_button(items: items)
