:ruby
  # fetch all the user records in one query
  user_ids = list.flat_map do |version|
    [ version.clean_user_id, version.clean_true_user_id]
  end
  users_by_id = User.with_deleted.where(id: user_ids.uniq).index_by(&:id)

  system_user = User.system_user
  version_usernames = {}
  list.each do |version|
    next if version.whodunnit == 'unauthenticated'

    true_user = users_by_id[version.clean_true_user_id]
    user = users_by_id[version.clean_user_id]
    if true_user && user && true_user != user
      username = [user.name, true_user.name].join(' impersonating ')
    else
      username = user&.name
    end
    version_usernames[version.id] = username
  end

.table-responsive
  %table.table.table-striped
    %thead
      %tr
        %th Date changed
        %th Editor
        %th Changes
    %tbody
      - list.each do |version|
        %tr
          %td= version.created_at.to_fs
          %td
            = version_usernames[version.id] || version.whodunnit.presence
          %td
            %pre.m-0= describe_changes_to(version)&.join("\n")
