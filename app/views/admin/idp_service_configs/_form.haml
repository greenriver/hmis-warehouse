.row
  .col-sm-8
    = simple_form_for [:admin, @idp_service_config] do |f|
      = f.error_notification
      .form-inputs
        = f.input :name, hint: 'Friendly name for this configuration'
        = f.input :provider, collection: ::Idp::ServiceFactory.supported_providers, as: :select_two, prompt: 'Select IDP type', hint: 'Which IDP integration to use'
        = f.input :connector_id, as: :string, hint: 'Routing key from the auth proxy — must match the JWT connector_id (Dex connector name)'
        = f.input :api_url, label: 'API URL', hint: 'Base URL for the IDP API'
        = f.input :client_id, as: :string, hint: 'Service-account client ID (Keycloak)'
        = f.input :keycloak_realm, as: :string, hint: 'Keycloak realm (required for Keycloak; no default)'
        = f.input :service_token, as: :password, input_html: { value: @idp_service_config.service_token }, hint: 'Service account token/password.'
        = f.input :okta_org_id, label: 'Okta Org ID', hint: 'Org identifier in Okta (optional)'
        = f.input :active, label: 'Active', hint: 'Only active configurations will be used'

      .form_actions
      = f.button :submit
