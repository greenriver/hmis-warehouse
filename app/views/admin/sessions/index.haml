- title = "Manage User Sessions"
- content_for :title, title

%h1= content_for :title
= render partial: 'menus/admin_tabs'

.card.admin-manage-session
  %table.table.table-fixed.table-striped.mb-0
    %thead
      %th Name
      %th Last Login
      %th Last Location
      %th Last Activity
      %th
        %i.icon-info{data: { 'bs-toggle' => :tooltip, title: 'Subject to updates based on last activity'}}
        Scheduled Expiration
      %th Force Logout
    %tbody
      - @users.each do |user|
        - last_login_activity = user.all_login_activities.successful.last
        %tr
          %td= link_to_if can_edit_users?, user.name, edit_admin_user_path(user)
          %td
            = user.current_sign_in_at
            = "(HMIS)" if last_login_activity&.hmis?
          %td= last_login_activity&.location_description
          %td= user.last_activity_at
          %td= user.last_activity_at + user.timeout_in
          %td
            = link_to admin_session_path(user),  method: :delete, data: {confirm: "Are you sure you want to end the session for #{user.name}? This action will immediately log the user out#{HmisEnforcement.hmis_enabled? ? ' of both HMIS and Warehouse' : ''}."}, class: 'btn btn-sm btn-danger mb-2 text-nowrap' do
              %i.icon-cross
              End Session
