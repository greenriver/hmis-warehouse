- title = 'Threshold Monitoring Definitions'
- content_for :title, title
%h1= content_for :title

.row
  .col-sm-12
    %p.text-muted
      Threshold monitoring definitions are hard-coded, but you can modify thresholds, display names, and activation status to fit your community's needs.
    = render_paginated_list(scope: @metric_definitions, item_name: 'threshold definition', list_partial: 'admin/metric_definitions/list')

    - if @import_csv_data_sources&.any?
      .well.mb-4
        %h4 CSV Import Thresholds (by Data Source)
        %p.text-muted
          Per-CSV import thresholds are configured per data source. Manage monitors, thresholds, and notifications from each data source's Import Thresholds page.
        - @import_csv_data_sources.each do |data_source|
          %h5.mt-3
            = link_to data_source.name, data_source_import_threshold_path(data_source)
          %table.table.table-sm.table-striped.mb-4
            %thead
              %tr
                %th CSV File
                %th Count Increase
                %th Count Decrease
                %th Min Additions
                %th Max Removals
                %th Active
                %th Actions
            %tbody
              - data_source.import_csv_monitors.order(:csv_file_name).each do |monitor|
                - metric_def = GrdaWarehouse::Monitoring::MetricDefinition.find_by(entity_type: 'GrdaWarehouse::DataSource', subtype: monitor.csv_file_name)
                %tr
                  %td= link_to monitor.csv_file_name, admin_metric_definition_path(metric_def, entity_id: data_source.id)
                  %td= monitor.count_increase_threshold.presence || '—'
                  %td= monitor.count_decrease_threshold.presence || '—'
                  %td= monitor.min_additions_threshold.presence || '—'
                  %td= monitor.max_removals_threshold.presence || '—'
                  %td
                    - if monitor.active
                      %span.badge.text-bg-primary Active
                    - else
                      %span.badge.text-bg-secondary Inactive
                  %td
                    = link_to 'Edit', edit_data_source_import_csv_monitor_path(data_source, monitor), class: 'btn btn-sm btn-primary'