- title = "Edit #{@metric_definition.display_name}"
- content_for :title, title

= content_for :crumbs do
  = link_to admin_metric_definitions_path do
    &laquo; Client Metric Definitions

%h1= content_for :title

= simple_form_for @metric_definition, url: admin_metric_definition_path(@metric_definition) do |f|
  = f.error_notification

  .row
    .col-sm-8
      .well
        = f.input :display_name, required: true, hint: 'Human-readable name shown in the UI'
        = f.input :description, as: :text, hint: 'Detailed description of what this metric measures'

      .well
        %h4 Change Detection Thresholds
        %p.text-muted
          Configure when to create a new snapshot (crossing the threshold).
          If both thresholds are set,
          %strong both
          must be met to create a new snapshot.

        = f.input :count_change_threshold,
          as: :integer,
          hint: 'Create new snapshot if value changes by at least this amount (e.g., 30 days)'

        = f.input :percent_change_threshold,
          as: :decimal,
          hint: 'Create new snapshot if value changes by at least this percentage (e.g., 10.0 for 10%)'

      .well
        = f.input :active,
          as: :boolean,
          hint: 'Inactive metrics are not calculated during collection runs'

      .form-actions.mt-4
        = link_to 'Cancel', admin_metric_definition_path(@metric_definition)
        = f.button :submit, 'Update Metric Definition', class: 'btn btn-primary ms-auto'


    .col-sm-4
      .card
        .card-body
          %h5.card-title Read-Only Configuration
          %dl.mb-0
            %dt Metric Name
            %dd
              %code= @metric_definition.name
            %dt Calculator Class
            %dd
              %code= @metric_definition.calculator_class
            %dt Entity Type
            %dd
              %code= @metric_definition.entity_type
          %p.text-muted.small.mt-3
            These values are set by the calculator class and cannot be modified through the UI.
