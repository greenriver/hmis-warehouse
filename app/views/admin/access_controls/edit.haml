= render 'breadcrumbs'

.d-flex
  %h1 Edit Access Control #{@access_control.name}
  .ml-auto
    = link_to admin_access_control_audit_path(@access_control), class: 'btn btn-info mb-3' do
      %i.fa.fa-history
      %span.icon-eye
      History
= render 'admin/access_controls/description', entity_type: 'warehouse'
.well
  = simple_form_for @access_control, as: :access_control, url: admin_access_control_path do |f|
    = f.error_notification
    .form-inputs.mt-4
      = render 'form', f: f
    .form_actions.mt-4
      = f.button :submit, value: 'Update Access Control'
