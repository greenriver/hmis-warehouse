= render 'cohort_columns/page_header'

.row
  .col-sm-8
    %h1= content_for :title

= render 'cohort_columns/tab_bar'

= simple_form_for :cohort_column, url: cohort_column_names_path do |f|
  %table.table.table-striped.w-100
    %thead
      %tr
        %th.w-20 Original Name
        %th Current Name
        %th.w-40 Description
        %th Type
        %th Active
    %tbody
      - columns = @columns.sort_by { |c| [c.cohort_column.active ? 0 : 1, c.title || c.class_name] }
      - columns.each do |column|
        - translatable = !column.class.in?(GrdaWarehouse::Cohort.non_translateable)
        %tr
          %td
            = column.translation_key
          %td
            = f.input "#{column.column}", label: false, input_html: { value: column.title } if translatable
          %td
            - if translatable
              - value = if column.show_description? then column.description else '' end
              - default = if column.show_default_description? then "Default: #{column.description_translation_key}" else '' end
              = f.input "#{column.column}_description", label: false, as: :text, input_html: { value: value }, hint: default
          %td
            - type = column_type(column)
            = type
            - if type == 'Read only'
              %i.icon-info{ data: { 'bs-toggle' => :tooltip, 'bs-title' => 'Calculation cannot be adjusted.  The description and column name should only be changed to increase clarity of the calculation.'}}
          %td
            = f.input "#{column.column}_active", label: false, as: :boolean, input_html: { checked: column.active? }

  .text-right
    = f.submit value: 'Update Column Names', class: 'btn btn-primary'
