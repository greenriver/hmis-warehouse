= simple_form_for import_csv_monitor, url: import_csv_monitor.persisted? ? data_source_import_csv_monitor_path(data_source, import_csv_monitor) : data_source_import_csv_monitors_path(data_source), method: import_csv_monitor.persisted? ? :patch : :post do |f|
  .row
    .col
      = f.input :csv_file_name,
                as: :select_two,
                collection: GrdaWarehouse::ImportCsvMonitor.allowed_csv_files,
                label: 'CSV File',
                hint: 'Select which CSV file to monitor'
    .col
      .pt-no-label= f.input :active, as: :pretty_boolean, label: 'Active'
  .row
    .col
      = f.input :count_increase_threshold,
                label: 'Count increase threshold',
                hint: 'Alert when net row increase exceeds this (optional)',
                input_html: { style: 'width: 8em' }
    .col
      = f.input :count_decrease_threshold,
                label: 'Count decrease threshold',
                hint: 'Alert when net row decrease exceeds this (optional)',
                input_html: { style: 'width: 8em' }
  .row
    .col
      = f.input :min_additions_threshold,
                label: 'Min additions threshold',
                hint: 'Alert when added rows are fewer than this (e.g. expect 500 new services/day)',
                input_html: { style: 'width: 8em' }
    .col
      = f.input :max_removals_threshold,
                label: 'Max removals threshold',
                hint: 'Alert when removed rows exceed this (e.g. alert if >100 enrollments deleted)',
                input_html: { style: 'width: 8em' }

  - if import_csv_monitor.persisted?
    %p.text-muted
      Add notification recipients in the Notifications section below to receive email alerts when thresholds are exceeded.
  .form-actions.d-flex.justify-content-between
    - unless import_csv_monitor.persisted?
      = link_to 'Cancel', data_source_import_threshold_path(data_source), class: 'btn btn-secondary mt-3'
    = f.submit import_csv_monitor.persisted? ? 'Update Monitor' : 'Create Monitor', class: 'btn btn-primary mt-3'
