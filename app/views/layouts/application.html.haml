!!!
%html(lang="en")
  %head
    %meta{name: "openpath-server", content: @op_hostname}
    %meta{:content => "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}/
    - if enable_responsive?
      %meta{:name=>"viewport", :content=>"width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=5.0"}
    %meta{:content => "IE=edge", "http-equiv" => "X-UA-Compatible"}
    = action_cable_meta_tag
    %title= [(strip_tags content_for(:title)).presence, Translation.translate('Open Path HMIS Warehouse')].compact.join(' :: ')
    %link{rel: :icon, type: 'image/png', href: 'data:;base64,iVBORw0KGgo='}
    %link{href: '//fonts.googleapis.com/css?family=Open+Sans:300,400,400italic,600,700|Open+Sans+Condensed:700|Poppins:400,300,500,700', rel: 'stylesheet', type: 'text/css'}
    = stylesheet_link_tag 'application', media: 'all'
    = stylesheet_link_tag 'print', media: 'print'

    - Dir.glob('app/assets/stylesheets/theme/styles/*.scss') do |stylesheet|
      - theme_styles = "theme/styles/#{File.basename(stylesheet, '.scss')}"
      = stylesheet_link_tag(theme_styles, media: 'all')
    - colors = Rails.cache.fetch('system-colors', expires_in: 5.minutes) { GrdaWarehouse::SystemColor.as_css.html_safe }
    - if colors.present?
      %style{ type: 'text/css' }
        = colors
    - # This block defines the default theme using CSS variables.
    - # In the future, this can be dynamically generated from a database query
    - # to apply client-specific themes.

    - # Select the correct theme stylesheet based on ENV['CLIENT']
    - # We use a logical path for stylesheet_link_tag, not a full filesystem path.
    - client_theme_name = ENV['CLIENT'].presence
    - css_path = ['app', 'assets', 'stylesheets', 'application', '_custom']
    - css_file = Rails.root.join(File.join(*css_path, "#{client_theme_name}.css"))
    - sheet_exists = client_theme_name && File.exist?(css_file)
    - sheet_name = sheet_exists ? client_theme_name : 'default'
    - css_file = Rails.root.join(File.join(*css_path, "#{sheet_name}.css"))
    %style{ type: 'text/css' }
      :plain
        /* #{sheet_name} */
        #{File.read(css_file)}
    - env_css_path = Rails.root.join(File.join(*css_path, 'env'))
    - env_css_file = Rails.root.join(File.join(*env_css_path, "#{Rails.env}.css"))
    - env_css_exists = File.exist?(env_css_file)
    - if env_css_exists
      %style{ type: 'text/css' }
        :plain
          /* #{env_css_file} */
          #{File.read(env_css_file)}
    = render 'layouts/favicon'
    = csrf_meta_tags
    = yield :head
  - data = {}
  - data.merge!({ spy: :scroll, target: '.scrollspy' }) if content_for(:body_data_scrollspy)
  %body{class: body_classes, data: data}
    = render 'layouts/header_warnings'

    %header.o-header--page
      .container-fluid.d-flex.align-items-center{class: container_classes}
        .site-name.d-flex
          .o-header--page__title.site-title
            = link_to root_path do
              = Translation.translate('Open Path HMIS Warehouse')
        .o-header--page__sub-title.tagline
          = Translation.translate('Ending Homelessness')
        - unless @maintenance
          - content_for :prepended_nav_items do
            = render 'layouts/warehouse_alert'
          = render 'layouts/header_nav'

    .l-main__wrapper
      - if user_signed_in?
        = render 'layouts/site_menu'

      .l-main__content{ class: ('with-menu' if user_signed_in?) }
        - if @layout__plain_inner
          = yield
        - else
          %main
            .container-fluid.mb-4{class: container_classes}
              .utility<
                = render "utility"
              - if content_for? :modal_title
                %h1
                  = yield :modal_title
              = yield
              - if content_for? :modal_footer
                .row
                  = yield :modal_footer
    %footer{ class: ('with-menu' if user_signed_in?) }
      .container-fluid.w-100{class: container_classes}
        .d-flex.align-items-center.pt-4.pb-6
          = render 'layouts/footer_seal'
          %p.site-description
            = Translation.translate('The Open Path HMIS Warehouse')
          - links = Link.for(:footer)
          - if links.present?
            .ml-4.custom-footer-content
              .text-right
                - links.each do |link|
                  .ml-auto
                    - if link.subject.present?
                      = mail_to link.url, link.label, subject: link.subject
                    - else
                      = link_to link.label, link.url
        .d-flex
          - if can_add_administrative_event? && Delayed::Job.exists?
            = render 'common/dj_status'
          .ml-auto
            = render 'common/logout_timing'

    #d3-tooltip
    = render 'layouts/ajax_modal_frame'
    = render 'document_exports/modal'
    = javascript_include_tag "cable_ready.umd.js", "data-turbo-track": "reload"
    = javascript_include_tag 'application'
    = javascript_include_tag 'application_esbuild'
    = javascript_include_tag('https://cdnjs.cloudflare.com/ajax/libs/chance/1.0.4/chance.min.js') if Rails.env.development?
    - if @per_page_js.present?
      - @per_page_js.each do |js_file|
        = javascript_include_tag js_file

    = yield :page_js
    = render "inactive_session_modal"
    = svg 'symbol-defs'

    :javascript
      window.sentryConfig = #{sentry_frontend_config.to_json};
