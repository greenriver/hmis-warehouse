        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-warning-ll);" }
          .c-color-key__title --brand-warning-ll
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-warning-lll);" }
          .c-color-key__title --brand-warning-lll
      .col-3
        %h3 Desaturated
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-warning-l-desaturated);" }
          .c-color-key__title --brand-warning-l-desaturated
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--bs-warning-desaturated);" }
          .c-color-key__title --bs-warning-desaturated

    %h2 Brand Danger Variants
    .row
      .col-3
        %h3 Darker
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-danger-d);" }
          .c-color-key__title --brand-danger-d
      .col-3
        %h3 Main
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-danger);" }
          .c-color-key__title --brand-danger
      .col-3
        %h3 Lighter
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-danger-l);" }
          .c-color-key__title --brand-danger-l
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-danger-ll);" }
          .c-color-key__title --brand-danger-ll
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-danger-lll);" }
          .c-color-key__title --brand-danger-lll
      .col-3
        %h3 Desaturated
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-danger-l-desaturated);" }
          .c-color-key__title --brand-danger-l-desaturated
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--bs-danger-desaturated);" }
          .c-color-key__title --bs-danger-desaturated

    %h2 Brand Info Variants
    .row
      .col-3
        %h3 Darker
      .col-3
        %h3 Main
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-info);" }
          .c-color-key__title --brand-info
      .col-3
        %h3 Lighter
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-info-l);" }
