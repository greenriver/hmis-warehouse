= render 'breadcrumbs'
%h1 Colors
.row
  .col-sm-10
    %h2 Bootstrap Theme Colors
    .d-flex.flex-row.flex-wrap.gap-2.mb-4
      .c-color-key
        .c-color-key__swatch{ style: "background-color: var(--bs-primary);" }
        .c-color-key__title --bs-primary
      .c-color-key
        .c-color-key__swatch{ style: "background-color: var(--bs-success);" }
        .c-color-key__title --bs-success
      .c-color-key
        .c-color-key__swatch{ style: "background-color: var(--bs-warning);" }
        .c-color-key__title --bs-warning
      .c-color-key
        .c-color-key__swatch{ style: "background-color: var(--bs-danger);" }
        .c-color-key__title --bs-danger
      .c-color-key
        .c-color-key__swatch{ style: "background-color: var(--bs-info);" }
        .c-color-key__title --bs-info

    %h2 Brand Primary Variants
    .row
      .col-3
        %h3 Darker
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-primary-d);" }
          .c-color-key__title --brand-primary-d
      .col-3
        %h3 Main
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-primary);" }
          .c-color-key__title --brand-primary
      .col-3
        %h3 Lighter
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-primary-l);" }
          .c-color-key__title --brand-primary-l
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-primary-ll);" }
          .c-color-key__title --brand-primary-ll
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-primary-lll);" }
          .c-color-key__title --brand-primary-lll
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-primary-llll);" }
          .c-color-key__title --brand-primary-llll
      .col-3
        %h3 Desaturated
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-primary-l-desaturated);" }
          .c-color-key__title --brand-primary-l-desaturated
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--bs-primary-desaturated);" }
          .c-color-key__title --bs-primary-desaturated

    %h2 Brand Success Variants
    .row
      .col-3
        %h3 Darker
      .col-3
        %h3 Main
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-success);" }
          .c-color-key__title --brand-success
      .col-3
        %h3 Lighter
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-success-l);" }
          .c-color-key__title --brand-success-l
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-success-ll);" }
          .c-color-key__title --brand-success-ll
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-success-lll);" }
          .c-color-key__title --brand-success-lll
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-success-llll);" }
          .c-color-key__title --brand-success-llll
      .col-3
        %h3 Desaturated
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-success-l-desaturated);" }
          .c-color-key__title --brand-success-l-desaturated
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--bs-success-desaturated);" }
          .c-color-key__title --bs-success-desaturated

    %h2 Brand Warning Variants
    .row
      .col-3
        %h3 Darker
      .col-3
        %h3 Main
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-warning);" }
          .c-color-key__title --brand-warning
      .col-3
        %h3 Lighter
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-warning-l);" }
