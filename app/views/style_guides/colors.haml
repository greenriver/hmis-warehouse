      .c-color-key
        .c-color-key__swatch{ style: "background-color: var(--theme-bright-blue);" }
        .c-color-key__title --theme-bright-blue

    %h2 Theme Background Colors
    .d-flex.flex-row.flex-wrap.gap-2.mb-4
      .c-color-key
        .c-color-key__swatch{ style: "background-color: var(--theme-background);" }
        .c-color-key__title --theme-background
      .c-color-key
        .c-color-key__swatch{ style: "background-color: var(--theme-background-l);" }
        .c-color-key__title --theme-background-l
      .c-color-key
        .c-color-key__swatch{ style: "background-color: var(--theme-foreground);" }
        .c-color-key__title --theme-foreground
      .c-color-key
        .c-color-key__swatch{ style: "background-color: var(--theme-alt-background);" }
        .c-color-key__title --theme-alt-background
      .c-color-key
        .c-color-key__swatch{ style: "background-color: var(--theme-background-d);" }
        .c-color-key__title --theme-background-d
      .c-color-key
        .c-color-key__swatch{ style: "background-color: var(--theme-background-highlight-d);" }
        .c-color-key__title --theme-background-highlight-d
      .c-color-key
        .c-color-key__swatch{ style: "background-color: var(--theme-background-highlight-dd);" }
        .c-color-key__title --theme-background-highlight-dd
      .c-color-key
        .c-color-key__swatch{ style: "background-color: var(--theme-background-d);" }
        .c-color-key__title --theme-background-d
  .col-sm-2= render 'pages'
