= render 'breadcrumbs'
%h1 System Colors
.row
  .col-sm-10
    %p
      The following are available by applying the classes as noted below or by fetching the colors directly in ruby:
      %pre.well
        %code
          color = GrdaWarehouse::SystemColor.first
          slug = 'project-type'
          id = 0
          background_color = color.color_for(slug, id)
          foreground_color = color.calculated_foreground_color(background_color)

    - colors = GrdaWarehouse::SystemColor.all.index_by(&:slug)
    .row.mt-6
      - GrdaWarehouse::SystemColor.default_colors.each do |section, colors|
        .col-sm-6
          %h2= section
          .well
            - colors.each do |i, color|
              - slug = "#{section}-#{i}"
              .mb-4.p-4{ class: slug } .#{slug}
  .col-sm-2= render 'pages'
