- if GrdaWarehouse::Config.get(:enable_external_data_sharing_exclusion)
  - exclusion = ClientExternalDataSharing.new(client)
  .d-inline-flex.align-items-center.gap-2.mb-2
    - if exclusion.excluded?
      %span.badge.text-bg-danger Excluded from External Data Sharing
    - else
      %span.badge.text-bg-secondary Included in External Data Sharing
    - if can_edit_clients?
      = link_to external_sharing_flag_client_path(client),
          class: 'text-muted',
          title: 'Edit external data sharing preference',
          data: { loads_in_ajax_modal: true } do
        %i.icon-pencil
