- exclusion = ClientExternalDataSharing.new(@client)

%section
  %header
    %h1 External Data Sharing
    = render 'clients/breadcrumbs'
    - if exclusion.embargoed?
      %p.mt-2
        %span.badge.text-bg-warning
          Automatically excluded from exports until
          = l(exclusion.embargo_expires_at.to_date, format: :long)
    %p
      When checked, this client will be excluded from the following data exchange mechanisms. 
      Both their client record and enrollment records will be omitted.
    %ul
      - ClientExternalDataSharing.exclusion_target_labels.each do |label|
        %li= label
    %p Unchecking restores them to exports at the next scheduled export run.

  = form_with url: client_external_data_sharing_path(@client), method: :patch do |f|
    .form-check.mb-3
      = f.check_box :exclude_from_external_data_sharing,
          { class: 'form-check-input', id: 'exclude_from_external_data_sharing',
            checked: exclusion.excluded? },
          '1', '0'
      = f.label :exclude_from_external_data_sharing,
          'Exclude from External Data Sharing',
          class: 'form-check-label',
          for: 'exclude_from_external_data_sharing'
    - if (info = exclusion.last_update_text)
      %p.text-muted= info
    = f.submit 'Save', class: 'btn btn-primary'
    = link_to 'Cancel', polymorphic_path(client_path_generator, id: @client.id), class: 'btn btn-secondary ms-2'
