:ruby
  addresses = @client.previous_permanent_locations_for_display(current_user).select{|m| m[:lat].present?}
  markers = addresses.map{ |m| {lat_lon: [m[:lat], m[:lon]], label: m[:label]} }.uniq
  lat = addresses.map{ |m| m[:lat] }
  lon = addresses.map{ |m| m[:lon] }
  bounds = [
    [lat.min, lon.min],
    [lat.max, lon.max],
  ]
  options = { permanent: true, cluster: false, bounds: bounds, marker_color: '#72A0C1' }
- if addresses.any? && markers.any?
  .p-3
    %h4 Previous Addresses
    .text--small * Approximate location based on zip code center

  #client__previous-addresses{data: { controller: 'map-with-markers', 'map-with-markers-markers-value': markers.to_json, 'map-with-markers-options-value': options.to_json }}
- else
  .no-data
    No previous addresses
