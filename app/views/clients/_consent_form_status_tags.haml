- status = @client.release_current_status
- state='success'
- icon='checkmark'

- if status == @client.class.no_release_string
  - state='warning'
  - icon='question'
- elsif status == 'Expired'
  - state='danger'
  - icon='clock'

.c-tag{ class: "c-tag--#{state}" }
  .c-tag__wrapper
    .c-tag__icon
      %div{ class: "icon-#{icon}" }
    .c-tag__content
      %span=status

- # there should be either zero or 1 authorizations
- rois = @client.roi_authorizations.order(:id).to_a
- if rois.any?
  - rois.each do |roi|
    .card.mt-3
      %table.table.mb-0
        %tr
          %th.fw-semibold.pr-2(scope="row")
            Effective Date of ROI
          %td
            = roi.starts_at ? roi.starts_at.to_fs : 'None'
        %tr
          %th.fw-semibold.border-0(scope="row")
            Expiration Date of ROI
          %td.border-0
            = roi.expires_at ? roi.expires_at.to_fs : 'None'
