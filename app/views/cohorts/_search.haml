.o-page__search
  = simple_form_for :search_form, url: cohorts_path, method: :get do |f|
    .input-group
      = f.input_field :q, label: false, placeholder: 'Search by cohort name or Client ID...', class: 'form-control', input_html: { value: @search_string }
      %button.btn.btn-secondary{type: :submit} Search
