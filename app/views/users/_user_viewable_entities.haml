- base ||= 'user'

-# TODO: START_ACL cleanup after ACL transition
- if @user.using_acls?
  %h3 User Access
  %p.alert.alert-info
    Access to data in the warehouse is granted through Access Controls.  Access Controls are a combination of a Role that grants permissions, a Collection that specifies where the permissions should be applied, and a User Group containing the members who should be granted the permission to the associated entities.  It is often easiest to choose an existing user whose permission is equivalent to what this user should have.  You can do that here, and further down the page, you can manually add the user to additional groups if necessary.
    Any Access Controls for the user will be listed at the bottom of the page after saving.
  - users = User.not_system.active.using_acls.to_a.map { |u| [u.name_with_email, u.id] }.reject { |_, id| id == @user.id }

  = f.input :copy_form_id, as: :select_two, label_method: :first, value_method: :last, collection: users, label: 'User to copy from'
  = f.association :user_groups, as: :select_two, collection: UserGroup.options_for_select, label: 'User Groups', input_html: { multiple: true }

- else
  %h3 Viewable Entities
  .alert.alert-info.align-items-start
    %i.icon-warning.mr-2.mt-2
    .alert__content
      Clients with records in specified data sources will be visible in the window to this user, regardless of data source visibility settings if they belong to a role with the
      %strong "Can see clients in window for assigned data sources"
      permission
  %ul.nav.nav-tabs.mb-0
    %li.nav-item
      %a.nav-link.active{href: '#user-roles', role: "presentation", data: { 'bs-toggle' => :tab}, aria: {controls:"user-roles", selected:"true"}}
        User Roles
    %li.nav-item
      %a.nav-link{href: '#user-groups', role: "presentation", data: { 'bs-toggle' => :tab}, aria: {controls:"user-groups", selected:"false"}}
        User Groups
    %li.nav-item
      %a.nav-link{href: '#data-access-assignments', role: "presentation", data: { 'bs-toggle' => :tab}, aria: {controls:"data-access-assignments", selected:"false"}}
        Data Access Assignments
    %li.nav-item
      %a.nav-link{href: '#reports-cohorts', role: "presentation", data: { 'bs-toggle' => :tab}, aria: {controls:"reports-cohorts", selected:"false"}}
        Reports &amp; Cohorts

  .tab-content
    .tab-pane.show.active.fade#user-roles{role: 'tabpanel', aria: {labelledby: 'user-roles'}}
      .c-columns
        = render 'users/roles', roles: roles, f: f, user: @user
    .tab-pane.fade#user-groups{role: 'tabpanel', aria: {labelledby: 'user-groups'}}
      .c-columns
        = render 'users/groups', f: f, user: @user
    .tab-pane.fade#data-access-assignments{role: 'tabpanel', aria: {labelledby: 'data-access-assignments'}}
      .c-columns
        - # Build base URL options for lazy loading
        - base_url_options = { base: base }
        - base_url_options[:id] = @user.id if @user.persisted?
        = render 'users/entity_column', entity: data_source_viewability(base).merge(lazy_load: true, entity_type: 'data_sources', base: base, load_options_url: load_select_options_admin_users_path(base_url_options.merge(entity_type: 'data_sources'))), entity_type: :data_sources, associations: [], f: f
        = render 'users/entity_column', entity: organization_viewability(base).merge(lazy_load: true, entity_type: 'organizations', base: base, load_options_url: load_select_options_admin_users_path(base_url_options.merge(entity_type: 'organizations'))), entity_type: :organizations, associations: [], f: f
        = render 'users/entity_column', entity: project_access_group_viewability(base).merge(lazy_load: true, entity_type: 'project_access_groups', base: base, load_options_url: load_select_options_admin_users_path(base_url_options.merge(entity_type: 'project_access_groups'))), entity_type: :project_access_groups, associations: [], f: f
        = render 'users/entity_column', entity: coc_viewability(base).merge(lazy_load: true, entity_type: 'coc_codes', base: base, load_options_url: load_select_options_admin_users_path(base_url_options.merge(entity_type: 'coc_codes'))), entity_type: :coc_codes, associations: [], f: f
        = render 'users/entity_column', entity: project_viewability(base).merge(lazy_load: true, entity_type: 'projects', base: base, load_options_url: load_select_options_admin_users_path(base_url_options.merge(entity_type: 'projects'))), entity_type: :projects, associations: [:data_source, :organization, :coc_code, :project_access_group], f: f


    .tab-pane.fade#reports-cohorts{role: 'tabpanel', aria: {labelledby: 'reports-cohorts'}}
      .c-columns
        = render 'users/entity_column', entity: user_reports_assignability(base).merge(lazy_load: true, entity_type: 'reports', base: base, load_options_url: load_select_options_admin_users_path(base_url_options.merge(entity_type: 'reports'))), entity_type: :reports, associations: [], f: f
        = render 'users/entity_column', entity: project_groups_editability(base).merge(lazy_load: true, entity_type: 'project_groups', base: base, load_options_url: load_select_options_admin_users_path(base_url_options.merge(entity_type: 'project_groups'))), entity_type: :project_groups, associations: [], f: f
        = render 'users/entity_column', entity: cohort_editability(base).merge(lazy_load: true, entity_type: 'cohorts', base: base, load_options_url: load_select_options_admin_users_path(base_url_options.merge(entity_type: 'cohorts'))), entity_type: :cohorts, associations: [], f: f

  - content_for :page_js do
    :javascript
      document.addEventListener('DOMContentLoaded', function() {
        // Wait for App namespace to be available
        if (typeof window.App !== 'undefined' && window.App.ViewableEntities) {
          new App.ViewableEntities();
        } else {
          // Fallback: wait a bit more and try again
          setTimeout(function() {
            if (typeof window.App !== 'undefined' && window.App.ViewableEntities) {
              new App.ViewableEntities();
            } else {
              console.error('App.ViewableEntities not found - check JavaScript load order');
            }
          }, 100);
        }
      });
