- @job_reports.each do |run_at, report|
  %tr{class: 'jIncompleteReport'}
    %td= run_at
    %td= report.user&.name
    %td= report.version
    %td= render 'spinner'
    %td= render 'parameters', report: report
    %td
- list.each do |report|
  %tr
    %td
      = report.created_at
      .text-sm.text-muted= report.runtime
    %td
      = report.user&.name
    %td
      = report.version
    %td
      = link_to warehouse_reports_hmis_export_url(report) do
        Download
    %td= render 'parameters', report: report
    %td
      - filter = report.options
      - items = [{ link_to: { path: "#{path_for_new}?#{{filter: filter}.to_query}"}, class: ['btn', 'btn-sm', 'btn-secondary'], icon: :copy, label: 'New report from this universe'}]
      - items << { link_to: { path: path_for_report(report), method: :delete, data: {confirm: 'Are you sure you want to delete this export?'}}, class: ['btn', 'btn-sm', 'btn-danger'], label: 'Delete export'}
      - if report.recurring_hmis_export.present? && can_cancel?(report)
        - items << { link_to: { path: edit_warehouse_reports_hmis_export_path(report)}, class: ['btn', 'btn-sm', 'btn-secondary'], icon: :pencil, label: 'Edit recurring export'}
        - items << { link_to: { path: cancel_warehouse_reports_hmis_export_path(report), method: :delete, data: { confirm: 'Are you sure you want to cancel this recurring export?'}}, class: ['btn', 'btn-sm', 'btn-secondary'], icon: 'clock-o', label: 'Cancel recurring export'}
      = action_menu_or_button(items: items)
