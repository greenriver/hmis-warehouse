.card
  %table.mb-0.table.table-striped
    %thead
      %tr
        %th Client
        %th Project Type
        %th Project
        %th Entry Date
        %th Exit Date
    %tbody
      - list.preload(:client).each do |enrollment|
        :ruby
          client = enrollment.client
          policy = current_user.policy_for(client)
          pii = GrdaWarehouse::PiiProvider.new(client, policy: policy)
        %tr
          %td
            - if policy.can_view?
              = link_to pii.brief_name, appropriate_client_path(id: client.id)
            -else
              = pii.brief_name
          %td= HudUtility2024.project_type(enrollment.project_type)
          %td= enrollment.project.name(current_user)
          %td= enrollment.first_date_in_program
          %td= enrollment.last_date_in_program
