.card
  %table.mb-0.table.table-striped
    %thead
      %tr
        %th Client
        %th Project Type
        %th Project
        %th Entry Date
        %th Exit Date
    %tbody
      - list.preload(:client).each do |enrollment|
        - client = enrollment.client
        %tr
          %td= link_to_if current_user.can_view_clients?, "#{client.FirstName} #{client.LastName}", appropriate_client_path(id: client.id)
          %td= HudUtility2024.project_type(enrollment.project_type)
          %td= enrollment.project.name(current_user)
          %td= enrollment.first_date_in_program
          %td= enrollment.last_date_in_program
