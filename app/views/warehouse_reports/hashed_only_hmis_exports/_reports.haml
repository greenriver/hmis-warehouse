- if params[:page].blank? || params[:page].to_i == 1
  - @job_reports.each do |run_at, report|
    %tr{class: 'jIncompleteReport'}
      %td= run_at
      %td= report.user&.name
      %td= report.version
      %td= render 'spinner'
      %td= render 'parameters', report: report
      %td
- list.each do |report|
  %tr
    %td
      = report.created_at
    %td
      = report.user&.name
    %td
      = report.version
    %td
      = link_to warehouse_reports_hashed_only_hmis_export_url(report) do
        Download
    %td= render 'parameters', report: report
    %td
      - filter = report.options
      - items = [{ link_to: { path: "#{path_for_new}?#{{filter: filter}.to_query}"}, class: ['btn', 'btn-sm', 'btn-secondary'], icon: :copy, label: 'New report from this universe'}]
      - items << { link_to: { path: path_for_report(report), method: :delete, data: {confirm: 'Are you sure you want to delete this export?'}}, class: ['btn', 'btn-sm', 'btn-danger'], label: 'Delete export'}
      = action_menu_or_button(items: items)
