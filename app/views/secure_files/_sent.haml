%h2 Sent
- if sent_secure_files.present?
  .card
    %table.table.table-striped
      %thead
        %tr
          %th
            File name
          %th
            Uploaded By
          %th
            Destined For
          %th
            Uploaded On
          %th
            Removal Date
          %th
            Remove
      %tbody
        - sent_secure_files.each do |file|
          %tr
            %td
              = link_to secure_file_path(file) do
                = file.name
            %td= file.sender&.name
            %td= file.recipient&.name
            %td= file.created_at.to_date
            %td= file.created_at.to_date + 1.month
            %td
              = link_to secure_file_path(file), method: :delete, class: 'btn btn-sm btn-icon-only btn-danger', data: { confirm: "Removing this file will also prevent the recipient from downloading it, are you sure you want to remove the file: \"#{file.name}\"?" } do
                %i.icon-cross
- else
  .none-found You have not sent any secure files in the past month.
