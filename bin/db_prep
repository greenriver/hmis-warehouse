#!/usr/bin/env ruby

# This is used to bootstrap local dev environments and to bootstrap
# brand new staging/production databases

require 'bundler/setup'  # make bundled gems like 'pg' available
require 'active_support/core_ext/object/blank'  # present?/blank?/presence for ERB in database.yml
require 'pathname'
require 'fileutils'
require 'pg'
require 'yaml'
require 'erb'

# path to your application root.
APP_ROOT = Pathname.new File.expand_path('..', __dir__)
DONT_CREATE_DATABASES = (ARGV[0] == '--no-create-databases')
NO_PRINT_DONE = (ARGV[1] == '--no-print-done')
CREATE_DATABASES = ! DONT_CREATE_DATABASES

def env
  ENV["RAILS_ENV"] || 'development'
end

def db(db_section)
  config =
    begin
      path = APP_ROOT.join( ENV.fetch("DB_YAML_PATH", "config/database.yml") ).to_s
      parsed = if env == 'development'
        YAML.safe_load(ERB.new(File.read(path)).result, aliases: true)
      else
        YAML.load_file(path)
      end
      parsed[env]
    end

  payload = {
    dbname: config[db_section]["database"],
    host: config[db_section]["host"],
    password: config[db_section]["password"],
    user: config[db_section]["username"],
  }

  if config[db_section]["sslrootcert"] && config[db_section]["sslmode"]
    payload.merge!({
      sslrootcert: config[db_section]["sslrootcert"],
      sslmode: config[db_section]["sslmode"],
    })
  end

  payload
end

def run_or_exit(cmd)
  return if system("alias psql='psql --single-transaction' && #{cmd}")

  puts 'Last command failed. Aborting.'

  exit(1)
end

def with_connection(db_section)
  section = db(db_section)
  conn = PG.connect(**section)
  yield(conn)
ensure
  conn&.close
end

def seeds_ran?(db_section)
  with_connection(db_section) do |conn|
    if db_section == "primary"
      result = conn.exec_params('SELECT count(*) FROM collections').entries
      num = result[0]["count"].to_i
      num > 0
    elsif db_section == "warehouse"
      result = conn.exec_params('SELECT count(*) FROM data_sources').entries
      num = result[0]["count"].to_i
      num > 0
    else
      raise "invalid db section of #{db_section}"
    end
  end
end

def db_is_initialized?(db_section)
  with_connection(db_section) do |conn|
    tables = conn.exec_params("SELECT * FROM information_schema.tables where table_catalog = $1 and table_type = 'BASE TABLE' and table_schema = 'public'", [ db(db_section)[:dbname] ]).entries
    tables.length > 1
  end
rescue PG::ConnectionBad => e
  if CREATE_DATABASES && e.message.match?(/database.+ does not exist/)
    false
  else
    raise e
  end
end

Dir.chdir APP_ROOT do
  env_to_pass = "RAILS_ENV=#{env}"
  env_to_pass = "#{env_to_pass} SKIP_TEST_DATABASE=true" if env == 'test'

  pre_initialized_dbs = ["primary", "warehouse", "health", "reporting"].select { |db_section| db_is_initialized?(db_section) }
  # Create the databases
  unless DONT_CREATE_DATABASES
    ["primary", "warehouse", "health", "reporting"].each do |db_section|
      if pre_initialized_dbs.include?(db_section)
        puts "\n== #{db_section} database is set up. Skipping init =="
      else
        puts "\n== Creating #{db_section} Database =="
        run_or_exit("#{env_to_pass} bundle exec rails db:create:#{db_section}")
      end
    end
  end

  # Load the schemas
  ["primary", "warehouse", "health", "reporting"].each do |db_section|
    next if pre_initialized_dbs.include?(db_section)

    puts "\n== Loading schema for #{db_section} Database =="
    run_or_exit("#{env_to_pass} bundle exec rails db:structure:conditional_load:#{db_section}")

    puts "\n== Migrating #{db_section} Database =="
    run_or_exit("#{env_to_pass} bundle exec rails db:migrate:#{db_section}")
  end


  if env != 'test'
    if seeds_ran?("primary")
      puts "\n== Seeds ran. Skipping initial seeding of primary database =="
    else
      puts "\n== Seeding Database =="
      run_or_exit("#{env_to_pass} bundle exec rails db:seed")
    end

    if seeds_ran?("warehouse")
      puts "\n== Warehouse seeds ran. Skipping initial seeding of warehouse database =="
    else
      run_or_exit("#{env_to_pass} bundle exec rails grda_warehouse:seed_grades")
      run_or_exit("#{env_to_pass} bundle exec rails grda_warehouse:seed_file_types")
    end

  else
    puts "\n== NOT Seeding test Database =="
  end
end
# do not modify the next line, it is used to determine when to stop during deployment
puts '---DONE---' unless NO_PRINT_DONE
