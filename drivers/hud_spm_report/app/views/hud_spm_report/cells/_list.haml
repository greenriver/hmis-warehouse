.card.overflow-x-scroll{style: "height: 800px"}
  %table.table.table-sm.table-bordered.table-fixed
    %thead.table-dark
      %tr
        %th
        - @drilldown.headers.each_value do |header|
          %th= header
    %tbody
      - # list contains SpmEnrollment, Episodes, or Returns
      - list.each.with_index do |client, i|
        - pii_policy = current_user.reporting_policy_for_project(project_id: client.project_id)
        %tr
          %th.table-dark= (@pagy.offset + i + 1)
          - @drilldown.headers.each_key do |k|
            %td{style: 'max-width: 600px;'}
              - if k.to_sym == :client_id
                = link_to appropriate_client_path(client[k]) do
                  = client[k]
                %a{href: '#', class: ['btn', 'btn-sm'], data: { 'bs-toggle' => :popover, title: 'Client Information', url: api_client_path(client.client_id), html: 'true' }}
                  %i.icon-info
              - elsif k.to_s.match?(/personal_id/)
                - # Using regex here as the personal_id header value is a nested key (e.g. 'enrollment.personal_id', exit_enrollment.personal_id, etc.)
                - value = client.display_value(k, pii_policy: pii_policy, include_content_tag: true)
                -# Client could have multiple source clients, only want to show the HMIS link for source client(s) in the data_source of the current SPM_enrollment/episode/return
                -# This should only be one client, but just in case of data issues, we'll loop through them all
                - client.client.source_clients.select { |sc| sc.data_source_id == client.data_source_id }.each do |hmis_client|
                  = hmis_external_link(hmis_client, user: current_user, wrapper_class: nil, text: value, icon_class: nil, icon_style: nil) || value
              - else
                = client.display_value(k, pii_policy: pii_policy, include_content_tag: true)
