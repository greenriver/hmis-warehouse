{
  "item": [
    {
      "text": "Date",
      "type": "DATE",
      "link_id": "date",
      "mapping": {
        "custom_field_key": "housing_workflow_denial_review_2_date"
      },
      "required": true
    },
    {
      "text": "Notes",
      "type": "TEXT",
      "link_id": "notes",
      "mapping": {
        "custom_field_key": "housing_workflow_denial_review_2_note"
      },
      "required": false
    },
    {
      "text": "Decision",
      "type": "CHOICE",
      "link_id": "denial_review_decision",
      "mapping": {
        "custom_field_key": "housing_workflow_denial_review_2_decision"
      },
      "required": true,
      "component": "RADIO_BUTTONS",
      "pick_list_options": [
        {
          "code": "1",
          "label": "Approve Denial"
        },
        {
          "code": "0",
          "label": "Send Back"
        }
      ]
    },
    {
      "text": "Decline Reason",
      "type": "CHOICE",
      "link_id": "denial_reason",
      "mapping": {
        "custom_field_key": "housing_workflow_denial_review_2_decline_reason"
      },
      "required": true,
      "component": "RADIO_BUTTONS",
      "enable_when": [
        {
          "operator": "EQUAL",
          "question": "denial_review_decision",
          "answer_code": "1"
