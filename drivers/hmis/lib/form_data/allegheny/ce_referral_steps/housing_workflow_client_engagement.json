{
  "item": [
    {
      "text": "Date",
      "type": "DATE",
      "link_id": "date",
      "required": true,
      "mapping": {
        "custom_field_key": "housing_workflow_client_engagement_date"
      }
    },
    {
      "text": "Notes",
      "type": "TEXT",
      "link_id": "notes",
      "required": false,
      "mapping": {
        "custom_field_key": "housing_workflow_client_engagement_note"
      }
    },
    {
      "text": "Continue with Referral?",
      "type": "CHOICE",
      "link_id": "move_forward",
      "required": true,
      "pick_list_options": [
        {
          "code": "1",
          "label": "Yes, continue"
        },
        {
          "code": "0",
          "label": "No, decline referral"
        }
      ],
      "mapping": {
        "custom_field_key": "housing_workflow_client_engagement_move_forward"
      }
    },
    {
      "text": "Decline Reason",
      "type": "CHOICE",
      "link_id": "decline_reason",
      "required": true,
      "pick_list_options": [
        {
          "code": "HMIS user error"
        },
        {
          "code": "Client needs to be reassessed"
        },
        {
          "code": "Does not meet eligibility criteria"
        },
        {
          "code": "No longer experiencing homelessness"
        },
        {
          "code": "Vacancy no longer available"
        },
        {
          "code": "Unable to currently engage with client"
        }
      ],
      "mapping": {
        "custom_field_key": "housing_workflow_client_engagement_decline_reason"
      },
      "enable_behavior": "ALL",
      "enable_when": [
        {
          "question": "move_forward",
          "operator": "EQUAL",
          "answer_code": "0"
        }
      ]
    },
    {
      "text": "Referral Result",
      "type": "CHOICE",
      "link_id": "referral_result",
      "helper_text": "Referral Result to store on the CE Event.",
      "mapping": {
        "custom_field_key": "housing_workflow_client_engagement_referral_result"
      },
      "required": true,
      "component": "RADIO_BUTTONS",
      "enable_when": [
        {
          "question": "move_forward",
          "operator": "EQUAL",
          "answer_code": "0"
        }
      ],
      "enable_behavior": "ALL",
      "pick_list_options": [
        {
          "code": "UNSUCCESSFUL_REFERRAL_CLIENT_REJECTED",
          "label": "Unsuccessful referral: client rejected"
        },
        {
          "code": "UNSUCCESSFUL_REFERRAL_PROVIDER_REJECTED",
          "label": "Unsuccessful referral: provider rejected"
        }
      ]
    }
  ]
}