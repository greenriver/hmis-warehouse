{
  "item": [
    {
      "text": "Date",
      "type": "DATE",
      "link_id": "date",
      "mapping": {
        "custom_field_key": "housing_workflow_provider_outcome_2_date"
      },
      "required": true
    },
    {
      "text": "Notes",
      "type": "TEXT",
      "link_id": "notes",
      "mapping": {
        "custom_field_key": "housing_workflow_provider_outcome_2_note"
      },
      "required": false
    },
    {
      "text": "Decision",
      "type": "CHOICE",
      "link_id": "move_forward",
      "mapping": {
        "custom_field_key": "housing_workflow_provider_outcome_2_move_forward"
      },
      "required": true,
      "component": "RADIO_BUTTONS",
      "pick_list_options": [
        {
          "code": "1",
          "label": "Accept - Enroll in Project"
        },
        {
          "code": "0",
          "label": "Decline - Submit Referral for Denial Review"
        }
      ]
    },
    {
      "text": "Decline Reason",
      "type": "CHOICE",
      "link_id": "denial_reason",
      "mapping": {
        "custom_field_key": "housing_workflow_provider_outcome_2_decline_reason"
      },
      "required": true,
      "component": "RADIO_BUTTONS",
      "enable_when": [
        {
          "operator": "EQUAL",
          "question": "move_forward",
          "answer_code": "0"
        }
      ],
      "enable_behavior": "ALL",
      "pick_list_options": [
        {
          "code": "HMIS user error"
        },
        {
          "code": "Inability to complete intake"
        },
        {
          "code": "Does not meet eligibility criteria"
        },
        {
          "code": "No longer interested in this program"
        },
        {
          "code": "No longer experiencing homelessness"
        },
        {
          "code": "Estimated vacancy no longer available"
        },
        {
          "code": "Enrolled, but declined HMIS data entry"
        }
      ]
    },
    {
      "text": "The client will be enrolled in the project when this form is submitted.",
      "type": "DISPLAY",
      "link_id": "enroll_message",
      "component": "ALERT_INFO",
      "enable_when": [
        {
          "operator": "EQUAL",
          "question": "move_forward",
          "answer_code": "1"
        }
      ],
      "enable_behavior": "ALL"
    }
  ]
}