            "data_collected_about": "HOH",
            "mapping": {
              "custom_field_key": "county_of_residence"
            }
          },
          {
            "text": "Does the client currently have a housing plan?",
            "type": "CHOICE",
            "link_id": "housing_plan",
            "required": true,
            "read_only": false,
            "warn_if_empty": false,
            "disabled_display": "HIDDEN",
