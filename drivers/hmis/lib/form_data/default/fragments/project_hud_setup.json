{
  "type": "GROUP",
  "link_id": "project_hud_setup_group",
  "text": "HUD Setup",
  "enable_behavior": "ALL",
  "enable_when": [
    {
      "local_constant": "$projectId",
      "operator": "EXISTS",
      "answer_boolean": false,
      "_comment": "Only show this group if creating a new project"
    }
  ],
  "item": [
    {
      "type": "GROUP",
      "link_id": "coc_group",
      "text": "Project CoC",
      "item": [
        {
          "type": "CHOICE",
          "required": true,
          "link_id": "coc",
          "text": "CoC Code",
          "pick_list_reference": "COC",
          "mapping": {
            "field_name": "initialCocCode"
          }
        },
        {
          "type": "CHOICE",
          "required": true,
          "link_id": "geocode",
          "text": "Geocode",
          "pick_list_reference": "GEOCODE",
          "mapping": {
            "field_name": "initialGeocode"
          }
        }
      ]
    },
    {
      "type": "GROUP",
      "link_id": "funder_group",
      "text": "Funder",
      "item": [
        {
          "type": "CHOICE",
          "required": false,
          "link_id": "funder",
          "text": "Funding Source",
          "pick_list_reference": "FundingSource",
          "mapping": {
            "field_name": "initialFunder"
          }
        },
        {
          "type": "OPEN_CHOICE",
          "required": true,
          "link_id": "other",
          "text": "Other Funder",
          "mapping": {
            "field_name": "initialOtherFunder"
          },
          "pick_list_reference": "OTHER_FUNDERS",
          "enable_behavior": "ALL",
          "enable_when": [
            {
              "question": "funder",
              "operator": "EQUAL",
              "answer_code": "LOCAL_OR_OTHER_FUNDING_SOURCE"
            }
          ]
        },
        {
          "type": "STRING",
          "required": true,
          "link_id": "grant_id",
          "text": "Grant Identifier",
          "mapping": {
            "field_name": "initialFunderGrantId"
          }
        }
      ]
    },
    {
      "type": "GROUP",
      "link_id": "hmis_participation_group",
      "text": "HMIS Participation",
      "item": [
        {
          "type": "CHOICE",
          "component": "DROPDOWN",
          "required": true,
          "link_id": "q_2_08_1",
          "text": "HMIS Participation Type",
          "pick_list_reference": "HMISParticipationType",
          "mapping": {
            "field_name": "initialHmisParticipationType"
          }
        }
      ]
    },
    {
      "type": "GROUP",
      "link_id": "hmis_ce_participation_group",
      "text": "HMIS CE Participation",
      "item": [
        {
          "type": "CHOICE",
          "required": true,
          "link_id": "q_2_09_1",
          "text": "Access Point",
          "pick_list_reference": "NoYes",
          "mapping": {
            "field_name": "initialCeAccessPoint"
          }
        },
        {
          "type": "GROUP",
          "link_id": "q_2_09_A_conditionals",
          "enable_behavior": "ALL",
          "enable_when": [
            {
              "question": "q_2_09_1",
              "operator": "EQUAL",
              "answer_code": "YES"
            }
          ],
          "item": [
            {
              "type": "CHOICE",
              "required": true,
              "link_id": "q_2_09_A_prevention",
              "text": "Prevention Assessment",
              "pick_list_reference": "NoYes",
              "mapping": {
                "field_name": "initialCePreventionAssessment"
              }
            },
            {
              "type": "CHOICE",
              "required": true,
              "link_id": "q_2_09_A_crisis",
              "text": "Crisis Assessment",
              "pick_list_reference": "NoYes",
              "mapping": {
                "field_name": "initialCeCrisisAssessment"
              }
            },
            {
              "type": "CHOICE",
              "required": true,
              "link_id": "q_2_09_A_housing",
              "text": "Housing Assessment",
              "pick_list_reference": "NoYes",
              "mapping": {
                "field_name": "initialCeHousingAssessment"
              }
            },
            {
              "type": "CHOICE",
              "required": true,
              "link_id": "q_2_09_A_services",
              "text": "Direct Services",
              "pick_list_reference": "NoYes",
              "mapping": {
                "field_name": "initialCeDirectServices"
              }
            }
          ]
        },
        {
          "type": "CHOICE",
          "required": true,
          "link_id": "q_2_09_2",
          "text": "Receives Referrals",
          "pick_list_reference": "NoYes",
          "mapping": {
            "field_name": "initialCeReceivesReferrals"
          }
        }
      ]
    }
  ]
}
