- title = "Edit Project Group: #{@project_group.name}"
= content_for(:title, title)
= content_for :crumbs do
  = link_to hmis_admin_project_group_path(@project_group) do
    &laquo; Back to #{@project_group.name}
- associated_collections = Hmis::AccessGroup.contains(@project_group).map(&:name).sort
- associated_workspaces = @project_group.workspaces.order(:applies_to, :sort_order, :name).map(&:name)
- used_for_ce_eligibility = @project_group.used_for_ce_eligibility?
- confirm_delete_msg = associated_collections.any? ? "The project group will be removed from the following HMIS Collections: #{associated_collections.join(', ')}. Users may lose access to HMIS data." : ''
- delete_blocked_reasons = []
- delete_blocked_reasons << "HMIS Workspaces: #{associated_workspaces.join(', ')}" if associated_workspaces.any?
- delete_blocked_reasons << 'CE eligibility (hmis_ce/eligibility_project_group_id)' if used_for_ce_eligibility
- delete_blocked_msg = "This project group cannot be deleted because it is used by: #{delete_blocked_reasons.join('; ')}. Clear those associations before deleting this project group."
.row
  .col-sm-10
    %h1.d-flex.justify-content-between.align-items-center
      = title
    .mt-8
    = simple_form_for @project_group, as: :filters, url: hmis_admin_project_group_path(@project_group) do |f|
      = render 'form', f: f
      .form-actions.d-flex
        - if delete_blocked_reasons.any?
          %span.d-inline-block{ data: { 'bs-toggle' => :tooltip, 'bs-title' => delete_blocked_msg } }
            %button.btn.btn-danger{ type: 'button', disabled: true }
              %i.icon-cross
              Delete Group
        - else
          = link_to hmis_admin_project_group_path(@project_group), method: :delete, class: 'btn btn-danger', data: { confirm: "Are you sure you want to delete this project group? #{confirm_delete_msg}" } do
            %i.icon-cross
            Delete Group
        = f.button :submit, class: 'btn btn-primary ml-auto', value: 'Save Project Group'
