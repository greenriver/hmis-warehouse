%html
  %head
    %meta{charset: 'UTF-8'}
    %style
      :plain
        body { font-family: sans-serif; font-size: 9px; margin: 0; }
        .footer { border-top: 1px solid #ccc; padding: 4px 40px; display: flex; justify-content: space-between; }
  %body
    .footer
      %span Printed: #{Date.current.to_fs(:long)}
      %span
        Page
        %span.pageNumber
        of
        %span.totalPages
