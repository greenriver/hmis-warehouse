= render 'breadcrumbs'
= render 'beta_warning'

- if @report.purged?
  = render 'warehouse_reports/reload_archived_report', report: @report, reload_url: reload_from_csv_performance_metrics_warehouse_reports_report_path(@report)
- else
  .well
    = render 'clients_served'
  .well
    = render 'returns'
  .well
    = render 'entering_housing'
  .well
    = render 'income'
  .well
    = render 'average_stay_length'
  .well
    = render 'inflow_outflow'
