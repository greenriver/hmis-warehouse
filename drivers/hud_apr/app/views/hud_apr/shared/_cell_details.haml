- column_headings = @generator.column_headings(@question)
= content_for :crumbs do
  = link_to path_for_question_result(@question, report: @report) do
    = "« #{report_short_name} #{@question} Results"
- content_for :title do
  = "#{report_short_name} #{@question}: #{@generator.describe_table(@question)} - #{@table} #{@cell}"
.d-flex.mb-2
  %h1= content_for :title
  .ml-auto
    = link_to(link_params.merge({format: :xlsx}),{class: 'btn btn-secondary'}) do
      %i.icon-file-excel
      Download

- if @clients.blank?
  .none-found No records found.
- else
  .d-flex.mb-4
    .mr-4
      .input-group
        %input#table_search.form-control{autofocus: true, type: :text, placeholder: 'Search...'}
        %button.btn.btn-secondary Search
  .card.overflow-x-scroll{style: "height: 800px"}
    %table.table.table-sm.table-bordered.table-fixed.datatable
      %thead.table-dark
        %tr
          %th
          - column_headings.each_value do |header|
            %th= header
      %tbody
        - current_user.policy_context.preload_project_dependencies(@clients.distinct.pluck(:project_id))
        - @clients.preload(:data_source, source_enrollment: :client).find_each.with_index do |client, i|
          - pii_policy = current_user.reporting_policy_for_project(project_id: client.project_id)
          %tr
            %th.table-dark= i + 1
            - column_headings.each_key do |k|
              %td{style: 'max-width: 600px;'}
                - if k.to_s == 'client_id'
                  = link_to from_source_client_path(client[k]) do
                    = client[k]
                  %a{href: '#', class: ['btn', 'btn-sm'], data: { 'bs-toggle' => :popover, title: 'Client Information', url: api_client_path(client.client_id), html: 'true' }}
                    %i.icon-info
                - elsif k.to_s == 'destination_client_id'
                  = link_to appropriate_client_path(client[k]) do
                    = client[k]
                  %a{href: '#', class: ['btn', 'btn-sm'], data: { 'bs-toggle' => :popover, title: 'Client Information', url: api_client_path(client.client_id), html: 'true' }}
                    %i.icon-info
                - elsif k.to_s.starts_with?('hiv_aids') && !can_view_hiv_status?
                  %i.light redacted
                - elsif k.to_s == 'personal_id'
                  - value = client.display_value(k, pii_policy: pii_policy, include_content_tag: true)
                  = hmis_external_link(client.source_enrollment.client, data_source: client.data_source, user: current_user, wrapper_class: nil, text: value, icon_class: nil, icon_style: nil) || value
                - else
                  = client.display_value(k, pii_policy: pii_policy, include_content_tag: true)
  = content_for :page_js do
    :javascript
      table = $('.datatable').DataTable({
        paging: false,
        "dom": 'lrtip'
      });
      $('#table_search').keyup(function(){
        table.search($(this).val()).draw() ;
      })
