= content_for :crumbs do
  = link_to path_for_question_result(@question, report: @report) do
    = "« #{report_short_name} #{@question} Results"
- content_for :title do
  = "#{report_short_name} #{@question} #{@cell}"
.d-flex.mb-2
  %h1= content_for :title
  .ml-auto
    = link_to(link_params.merge({format: :xlsx}),{class: 'btn btn-secondary'}) do
      %i.icon-file-excel
      Download



- if @clients.blank?
  .none-found No records found.
- else
  .card
    .overflow-x-scroll{style: "height: 800px"}
      %table.table.table-sm.table-bordered.table-fixed
        %thead.table-dark
          %tr
            %th
            - HudPathReport::Fy2020::PathClient.detail_headers.each_value do |header|
              %th= header
        %tbody
          - current_user.policy_context.preload_project_dependencies(@clients.distinct.pluck(:project_id))
          - @clients.preload(:data_source, :client).each.with_index do |client, i|
            - pii_policy = current_user.reporting_policy_for_project(project_id: client.project_id)
            %tr
              %th= i + 1
              - HudPathReport::Fy2020::PathClient.detail_headers.each_key do |k|
                %td{style: 'max-width: 600px;'}
                  - if k == 'client_id'
                    = link_to from_source_client_path(client[k]) do
                      = client[k]
                    %a{href: '#', class: ['btn', 'btn-sm'], data: { 'bs-toggle' => :popover, title: 'Client Information', url: api_client_path(client.client_id), html: 'true' }}
                      %i.icon-info
                  - elsif k == 'destination_client_id' && client[k].present?
                    = link_to client[k], appropriate_client_path(client[k])
                    %a{href: '#', class: ['btn', 'btn-sm'], data: { 'bs-toggle' => :popover, title: 'Client Information', url: api_client_path(client.client_id), html: 'true' }}
                      %i.icon-info
                  - elsif k == 'contacts'
                    = count_dates(client[k])
                  - elsif k == 'personal_id'
                    - value = client.display_value(k, pii_policy: pii_policy, include_content_tag: true)
                    = hmis_external_link(client.client, data_source: client.data_source, user: current_user, wrapper_class: nil, text: value, icon_class: nil, icon_style: nil) || value
                  - else
                    = client.display_value(k, pii_policy: pii_policy, include_content_tag: true)
