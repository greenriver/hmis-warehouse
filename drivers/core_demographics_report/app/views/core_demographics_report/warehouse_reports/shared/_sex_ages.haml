- reports = [@report]
- column_class = 'col-sm-8'
- if @report.include_comparison?
  - reports << @comparison
  - column_class = 'col-sm-6'
.row
  - reports.each_with_index do |report, index|
    - comparison_class = ''
    - if reports.count > 1
      - comparison_class = "c-swatch__border-left--td-#{index}"
    %div{class: column_class}
      - content_for "panel_collapse_content_sex_age_#{index}".to_sym do
        %div.panel-group.mb-0.panel-collapsible{id: "sex-age__core-demographics-#{index}"}
        .mb-0{class: comparison_class}
          %table.table
            %thead
              %tr
                %th Sex
                %th Age Range
                %th Count
                %th Percentage
            %tbody
              - report.sexes.each do |sex_col, sex_label|
                - report.age_categories.each do |age_range, age_title|
                  %tr
                    %th= sex_label
                    %th= age_title
                    %td
                      = link_to_if @report.can_see_client_details?(current_user), number_with_delimiter(report.sex_age_count(sex: sex_col, age_range: age_range)), polymorphic_path(@report.detail_path_array, report.filter.for_params.deep_merge(key: "age_#{age_range}_sex_#{sex_col}", filters: { start: report.filter.start_date, end: report.filter.end_date })), target: :_blank
                    %td= number_to_percentage(report.sex_age_percentage(sex: sex_col, age_range: age_range), precision: 2)
      = render 'common/panel_collapse', id: "sex-age-#{index}", title: 'Sex Age Breakdowns', content: "_sex_age_#{index}", panel_body_padded: 'n', default_open: @pdf ? 'yes' : 'no', allow_toggle: @pdf ? 'no' : 'yes'
