.jUploadSignatureForm
  = render 'health/health_files/form_fields', f: f, include_submit: false, include_note: false

- content_for :page_js do
  :javascript
    $(document).ready(function() {
      $('.jUploadSignatureForm').on('change', function(e) {
        signature_date = $('#health_pctp_careplan_patient_signed_on')
        if(signature_date.val() == '') {
          const today = new Date();
          const formattedDate = today.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
          signature_date.val(formattedDate);
        }
      });
    });
