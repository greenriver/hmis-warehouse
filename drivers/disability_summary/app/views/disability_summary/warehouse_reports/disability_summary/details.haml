- title = "Support for #{@report.support_title(params)}"
- content_for :title, title
%h1= title
- data = @report.detail_data(params)
- if data
  %p Showing data for #{pluralize(data.count, 'unique client')}.

  %h3 Sex
  .card.mb-6
    %table.table.table-striped
      %thead
        %tr
          - HudHelper.util.sexes.values.each do |sex|
            %th= sex
          %th Missing
      %tbody
        %tr
          - HudHelper.util.sexes.keys.each do |sex|
            %td= data.count { |row| row[:sex] == sex }
          %td= data.count { |row| row[:sex].nil? }
  %h3 Age
  .card.mb-6
    %table.table.table-striped
      %thead
        %tr
          - GrdaWarehouse::Hud::Client.extended_age_groups.each_value do |group|
            %th= group[:name]
      %tbody
        %tr
          - GrdaWarehouse::Hud::Client.extended_age_groups.each_value do |group|
            %td= data.count { |row| group[:range].include?(row[:reporting_age]) }
  %h3 Race
  .card.mb-6
    %table.table.table-striped
      %thead
        %tr
          - HudHelper.util.races(multi_racial: true).values.each do |race|
            %th= race
      %tbody
        %tr
          - HudHelper.util.races(multi_racial: true).keys.each do |race|
            %td= data.count { |row| row[:race] == race }
