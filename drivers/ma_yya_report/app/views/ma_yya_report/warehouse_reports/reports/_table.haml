.table-responsive
  %table.table.table-striped
    %thead
      %tr
        %th Status
        %th Options
        %th Actions
    %tbody.report-listing.warehouse-reports__completed
      - @reports.each do |report|
        %tr
          %td
            = link_to_if(report.completed?, report.status, ma_yya_report_warehouse_reports_report_path(report))
            .text-muted.description
              Run by: #{report.user&.name}
              %br
              = report.created_at
          %th
            = report.describe_filter_as_html
          %td
            - filter = report.options
            - items = [{ link_to: { path: "#{ma_yya_report_warehouse_reports_reports_path}?#{{filter: filter}.to_query}"}, class: ['btn', 'btn-sm', 'btn-secondary'], icon: :copy, label: 'New report from this universe'}]
            - items << { link_to: { path: ma_yya_report_warehouse_reports_report_path(report), method: :delete, data: {confirm: 'Are you sure you want to delete this report?'}}, class: ['btn', 'btn-sm', 'btn-danger'], label: 'Delete report'}
            = action_menu_or_button(items: items)
