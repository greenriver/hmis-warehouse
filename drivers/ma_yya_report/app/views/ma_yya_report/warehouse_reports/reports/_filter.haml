= simple_form_for @filter, as: :filter, url: ma_yya_report_warehouse_reports_reports_path do |f|
  - content_for :filters_col_full do
    .row
      .col-sm-3
        = f.input :start, as: :date_picker
      .col-sm-3
        = f.input :end, as: :date_picker
      .col-sm-6
        = f.input :coc_codes, collection: @filter.coc_code_options_for_select(user: current_user), as: :select_two, input_html: { multiple: true, placeholder: 'Choose CoCs' }, label: 'CoC Codes', hint: 'If any  CoC Codes are selected, Project CoC, Enrollment, and Inventory records will be limited to those with the chosen CoC Codes.'
    .row
      .col-sm-6
        = f.input :project_ids, label: 'Projects', collection: [], as: :select_two, input_html: { multiple: true, placeholder: 'Any Project', data: {'collection-path' => api_projects_path(selected_project_ids: @filter.project_ids)}}, include_blank: false
      .col-sm-6
        = f.input :project_group_ids, collection: @filter.project_groups_options_for_select(user: current_user), placeholder: 'Any Project Group', input_html: {multiple: true}, label: 'Project Groups', as: :select_two
      .col-sm-6
        = f.input :organization_ids, collection: @filter.organization_options_for_select(user: current_user), as: :grouped_select_two, group_method: :last, placeholder: 'Any Organization', input_html: { multiple: true }, label: 'Organizations'
      .col-sm-6
        = f.input :data_source_ids, collection: @filter.data_source_options_for_select(user: current_user), placeholder: 'Any Data Source', input_html: { multiple: true }, label: 'Data Sources', as: :select_two
    .row
      .col-sm-2
        = f.input :age_ranges, collection: MaYyaReport::Report.available_age_ranges.invert, as: :select_two, input_html: { multiple: true }, required: true
  - content_for :filter_actions do
    = f.submit 'Queue Report', class: ['btn', 'btn-primary']

  = render 'warehouse_reports/filters', f:f
