= content_for :crumbs do
  = link_to path_for_question_result(@question, report: @report) do
    = "« #{report_short_name} #{@question} Results"
- content_for :title do
  = "#{report_short_name} #{@question} #{@cell}"
.d-flex.mb-2
  %h1= content_for :title
  .ml-auto
    = link_to(link_params.merge({format: :xlsx}),{class: 'btn btn-secondary'}) do
      %i.icon-file-excel
      Download


- pii_cells = HudDataQualityReport::Fy2020::DqClient.pii_attributes_config.keys
- if @clients.blank?
  .none-found No records found.
- else
  .card
    .overflow-x-scroll{style: "height: 800px"}
      %table.table.table-sm.table-bordered.table-fixed
        %thead.thead-dark
          %tr
            %th
            - HudDataQualityReport::Fy2020::DqClient.detail_headers.each_value do |header|
              %th= header
        %tbody.thead-dark
          - current_user.policy_context.preload_project_dependencies(@clients.distinct.pluck(:project_id)) 
          - @clients.each.with_index do |client, i|
            - pii_policy = current_user.policy_for(nil, policy_class: GrdaWarehouse::AuthPolicies::LegacyPiiPolicy)
            - pii_policy = current_user.policy_for(client.project_id, policy_class: GrdaWarehouse::AuthPolicies::ProjectPiiPolicy) if client.project_id
            %tr
              %th= i + 1
              - HudDataQualityReport::Fy2020::DqClient.detail_headers.each_key do |k|
                %td{style: 'max-width: 600px;'}
                  - if k == 'client_id'
                    = link_to from_source_client_path(client[k]) do
                      = client[k]
                    %a{href: '#', class: ['btn', 'btn-sm'], data: { toggle: :popover, title: 'Client Information', url: api_client_path(client.client_id), html: 'true' }}
                      %i.icon-info
                  - elsif k.to_s == 'destination_client_id'
                    = link_to appropriate_client_path(client[k]) do
                      = client[k]
                    %a{href: '#', class: ['btn', 'btn-sm'], data: { toggle: :popover, title: 'Client Information', url: api_client_path(client.client_id), html: 'true' }}
                      %i.icon-info
                  - elsif k.to_s.starts_with?('hiv_aids') && !can_view_hiv_status?
                    %i.light redacted
                  - else
                    = client.display_value(k, pii_policy: pii_policy, include_content_tag: true)
