:ruby
  markdown = Redcarpet::Markdown.new(::InlineHtml)
  category_tables = @provider_comparison.included_categories.each_key.filter_map do |category_name|
    table = @provider_comparison.table(category_name)
    table[:projects].any? ? [category_name, table] : nil
  end.to_h
= render 'chosen_universe'
= render 'report_tabs'

.row
  .col-sm-3
    .card.mb-4
      .card-body
        %h5.card-title Project List
        .btn-group.mb-3{role: 'group'}
          = link_to 'My Projects', provider_comparisons_performance_measurement_warehouse_reports_report_path(@provider_comparison.report, active_project_list: :my_projects), class: "btn btn-sm #{@provider_comparison.active_project_list == :my_projects ? 'btn-primary' : 'btn-outline-primary'}"
          = link_to 'All Projects', provider_comparisons_performance_measurement_warehouse_reports_report_path(@provider_comparison.report, active_project_list: :all_projects), class: "btn btn-sm #{@provider_comparison.active_project_list == :all_projects ? 'btn-primary' : 'btn-outline-primary'}"
        %h5.card-title.mt-4 Jump to Category
        %nav
          %ul.nav.nav-pills.flex-column
            - category_tables.each_key do |category_name|
              %li.nav-item
                = link_to category_name, "##{category_name.parameterize}", class: 'nav-link'

    .card.mb-4
      .card-body
        %h5.card-title Color Key
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-success-lll);" }
          .c-color-key__title Passed
        .c-color-key.mb-2
          .c-color-key__swatch{ style: "background-color: var(--brand-warning-lll);" }
          .c-color-key__title Approaching threshold
        .c-color-key
          .c-color-key__swatch{ style: "background-color: var(--brand-danger-lll);" }
          .c-color-key__title Failed

  .col-sm-9
    - if category_tables.empty?
      .none-found No projects are available to display for the selected project list.
    - category_tables.each do |category_name, table|
      .page-break-after.mb-6{id: category_name.parameterize}
        %h2.mb-0.pb-6= category_name
        .card
          %table.table
            %thead
              %tr
                %th
                - table[:headers].group_by { |detail, header| header[:category] }.each.with_index do |(category, grouped_headers), index|
                  - class_name = "performance-measurement--highlight-light-#{index + 1}"
                  %th{colspan: grouped_headers.size, class: class_name}
                    %h3= category
              %tr
                %th
                - table[:headers].each do |detail, header|
                  %th= header[:title]
              %tr
                %th Goal or Target
                - table[:system].each do |detail, data|
                  %td{ data: { 'bs-toggle' => :tooltip, 'bs-title' => raw(markdown.render(data[:tooltip])), 'bs-html' => 'true' }}= raw markdown.render(data[:goal_description])
            %tbody
              %tr
                %td System Level
                - table[:system].each do |detail, data|
                  %td{class: data[:decorator]}= data[:display_value]
              - table[:projects].each do |project_id, data|
                %tr
                  %td= link_to_if can_view_projects?, data[:project_name], project_path(project_id)
                  - data[:values].each do |detail, result|
                    - data = {}
                    - data = {data: { 'bs-toggle' => :tooltip, 'bs-title' => raw(markdown.render(result[:tooltip])), 'bs-html' => 'true' }} if result[:tooltip].present?
                    %td{class: result[:decorator], **data}
                      - if result[:display_value].present?
                        = result[:display_value]
                      - else
                        .text-muted= 'N/A'
