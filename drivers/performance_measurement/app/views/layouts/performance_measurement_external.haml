%html(lang="en")
  %meta{:content => "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}/
  %meta{:content => "IE=edge", "http-equiv" => "X-UA-Compatible"}
  %title= [@report.instance_title, Translation.translate('Open Path HMIS Warehouse')].join(' :: ')
  %link{href: '//fonts.googleapis.com/css?family=Open+Sans:300,400,400italic,600,700|Open+Sans+Condensed:700|Poppins:400,300,500,700', rel: 'stylesheet', type: 'text/css'}
  <link rel="stylesheet" media="all" href="./application.css" type="text/css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/billboard.js/3.15.1/billboard.min.css" integrity="sha384-9TY8MiSSDr+71iqZPdpNhc5Nz4pn5XAUrdn74JR3CBwpy4zHj6ZKo2br2jdaJETO" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.6.1/font/bootstrap-icons.min.css" integrity="sha384-CWA4gK8kkTVT8C3fc1gcBw9VVNEEa0VpJvgYzsb/lrBkubzOgn0D6+dsHdUIMjC" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" integrity="sha384-4Q6Gf2aSP4eDXB8Miphtr37CMZZQ5oXLH2yaXMJ2w8e2ZtHTl7GptT4jmndRuHDT" crossorigin="anonymous">
  <script src="https://d3js.org/d3.v7.min.js" integrity="sha384-CjloA8y00+1SDAUkjs099PVfnY2KmDC2BZnws9kh8D/lX1s46w6EPhpXdqMfjK6i" crossorigin="anonymous"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/billboard.js/3.15.1/billboard.min.js" integrity="sha384-4laaO2DYUbBGszZQNn7IyKO+K9nvIW2gOwUoqQvg9alXTqEO2m+MR6QWpzCop2b4" crossorigin="anonymous"></script>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha384-1H217gwSVyLSIfaLxHbE7dRb3v4mYCKbpQvzx0cegeju1MVsGrX5xXxAvs/HgeFs" crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.min.js" integrity="sha384-RuyvpeZCxMJCqVUGFI0Do1mQrods/hhxYlcVfGPOfQtPJh0JCw12tUAZ/Mv10S7D" crossorigin="anonymous"></script>


  :css
    body {
      background-color: transparent;
    }
    body {
      font-family: 'Poppins', sans-serif;
      font-style: normal;
      font-weight: 300;
      font-size: 1rem;
    }
    .completed-at {
      font-size: 0.75rem;
      color: #8D8D8D;
      text-align: right;
      margin-right: 2em;
    }


  %body
    = yield

    %p.completed-at
      = Translation.translate('Data accurate as of')
      #{@report.completed_at.to_date}
    = yield :page_js
